# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# LibreClinica Configuration
LIBRECLINICA_SOAP_URL=http://localhost:8090/libreclinica-ws/ws
LIBRECLINICA_DB_HOST=localhost
LIBRECLINICA_DB_PORT=5432
LIBRECLINICA_DB_NAME=libreclinica
LIBRECLINICA_DB_USER=postgres
LIBRECLINICA_DB_PASSWORD=password
LIBRECLINICA_DB_MAX_CONNECTIONS=20

# SOAP Authentication
SOAP_USERNAME=root
SOAP_PASSWORD=root

# JWT Configuration  
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 21 CFR Part 11 Compliance
PASSWORD_EXPIRY_DAYS=90
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
SESSION_TIMEOUT_MINUTES=30

# Security
ALLOWED_ORIGINS=http://localhost:4200
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# ===========================================
# BACKUP CONFIGURATION (21 CFR Part 11)
# ===========================================

# Directory where backups are stored
BACKUP_DIR=./backups

# Docker container name for PostgreSQL
BACKUP_CONTAINER=libreclinica-postgres

# Enable/disable automatic backup scheduling
BACKUP_SCHEDULER_ENABLED=true

# Timezone for backup schedules (default: UTC)
BACKUP_TIMEZONE=UTC

# ===========================================
# AI VALIDATION-RULE COMPILER (optional)
# ===========================================
# Powers POST /api/validation-rules/compile (frontend "Suggest with AI" modal).
# Suggestions are reviewed by a human and signed before persistence.
#
# Provider options:
#   mock   - deterministic, no API key required (for local dev / CI / failover)
#   openai - requires OPENAI_API_KEY
#   gemini - requires GEMINI_API_KEY
AI_COMPILER_ENABLED=false
AI_COMPILER_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-2024-11-20
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
AI_COMPILER_TEMPERATURE=0
AI_COMPILER_TIMEOUT_MS=60000
AI_COMPILER_MAX_FIELDS=500
AI_COMPILER_MAX_DESCRIPTION_CHARS=8000
AI_COMPILER_MAX_RULES_HARD_CAP=20
AI_COMPILE_RATE_LIMIT_MAX=20

# ═══════════════════════════════════════════════════════════════════
# Email / SMTP Configuration
# ═══════════════════════════════════════════════════════════════════
EMAIL_QUEUE_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=AccuraTrials EDC
SMTP_FROM_EMAIL=noreply@accuratrials.com
EMAIL_PROCESS_INTERVAL=30000

# Protocol-to-eCRF AI Pipeline
PROTOCOL_PIPELINE_URL=http://localhost:8100
PROTOCOL_PIPELINE_TIMEOUT_MS=30000

